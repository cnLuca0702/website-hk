<%- include('partials/header') %>

<section class="hero">
  <div>
    <h1>景湖苑小区信息公示</h1>
    <p>社区信息、业委会信息、物业信息统一公示，支持附件在线浏览，便于业主随时查阅。</p>
  </div>
  <% if (currentUser) { %>
    <a class="primary-cta" href="<%= basePath %>/posts/new">立即发布</a>
  <% } else { %>
    <a class="primary-cta" href="<%= basePath %>/login">登录后发布</a>
  <% } %>
</section>

<section class="panel">
  <div class="section-head">
    <h2>分类筛选</h2>
    <p class="muted">共 <%= posts.length %> 条公示</p>
  </div>

  <div class="filters">
    <a class="chip <%= !activeCategory ? 'active' : '' %>" href="<%= basePath %>/">全部</a>
    <% Object.entries(categories).forEach(([key, label]) => { %>
      <a class="chip <%= activeCategory === key ? 'active' : '' %>" href="<%= basePath %>/?category=<%= key %>"><%= label %></a>
    <% }) %>
  </div>
</section>

<section class="list">
  <% if (!posts.length) { %>
    <article class="card empty">
      <p>暂无公示内容。</p>
    </article>
  <% } %>

  <% posts.forEach(post => { %>
    <article class="card">
      <div class="card-head">
        <h2><a href="<%= basePath %>/post/<%= post.id %>"><%= post.title %></a></h2>
        <span class="badge"><%= post.categoryLabel %></span>
      </div>
      <p class="meta">
        发布人：<%= post.authorName %> · 发布时间：<%= new Date(post.createdAt).toLocaleString('zh-CN') %>
      </p>
      <p><%= post.content.slice(0, 150) %><%= post.content.length > 150 ? '...' : '' %></p>
      <div class="card-foot">
        <span class="muted">附件数量：<%= post.attachmentCount %></span>
        <div class="row-actions">
          <a href="<%= basePath %>/post/<%= post.id %>">查看详情</a>
          <% if (post.canManage) { %>
            <a href="<%= basePath %>/post/<%= post.id %>/edit">编辑</a>
            <form action="<%= basePath %>/post/<%= post.id %>/delete" method="post" class="inline-form" onsubmit="return confirm('确认删除该公示吗？');">
              <button type="submit" class="link-danger">删除</button>
            </form>
          <% } %>
        </div>
      </div>
    </article>
  <% }) %>
</section>

<%- include('partials/footer') %>
